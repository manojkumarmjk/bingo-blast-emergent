    "scale": {
      "h1": { "fontSize": 40, "fontWeight": "900", "letterSpacing": 1, "lineHeight": 48 },
      "h2": { "fontSize": 32, "fontWeight": "800", "letterSpacing": 0.5, "lineHeight": 40 },
      "h3": { "fontSize": 24, "fontWeight": "800", "letterSpacing": 0, "lineHeight": 32 },
      "title": { "fontSize": 20, "fontWeight": "700", "lineHeight": 28 },
