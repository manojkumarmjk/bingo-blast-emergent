      "body": { "fontSize": 16, "fontWeight": "600", "lineHeight": 24 },
      "caption": { "fontSize": 14, "fontWeight": "500", "lineHeight": 20 },
      "badge": { "fontSize": 11, "fontWeight": "800", "letterSpacing": 1, "textTransform": "uppercase" }
