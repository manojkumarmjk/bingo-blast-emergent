{
  "theme_and_archetype": {
    "archetype": "Archetype 6: Vibrant Play mixed with Premium Casino-Style",
    "theme_mode": "dark",
    "description": "Modern, colorful, premium gaming UI with playful Bingo energy. Uses a deep night-purple background to make bright neon gradients, gold coins, and colorful bingo balls pop. Trust cues established through high-quality 3D assets, thick pill buttons, glowing effects, and smooth rounded geometry."
